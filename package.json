    "templates",
    "scripts/postinstall.js",
    "README.md"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.12",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}
